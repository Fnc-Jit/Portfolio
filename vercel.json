{
    "buildCommand": null,
    "outputDirectory": ".",
    "framework": null,
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ],
    "headers": [
        {
            "source": "/public/certs/(.*)",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "application/pdf"
                }
            ]
        },
        {
            "source": "/(.*).pdf",
            "headers": [
                {
                    "key": "Content-Type",
                    "value": "application/pdf"
                }
            ]
        }
    ]
}